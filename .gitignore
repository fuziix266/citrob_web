# Dependencias Composer
/vendor/

# Imágenes de productos (se generan en el servidor, no van al repo)
/public/img/products/

# Caché de configuración de Laminas
/data/cache/*.php
!/data/cache/.gitkeep

# Config local con credenciales (NO subir al repo)
/config/autoload/database.local.php
/config/autoload/local.php
/config/autoload/*.local.php
!/config/autoload/*.local.php.dist

# Logs
/data/logs/

# Laminas development mode
/config/development.config.php
/config/autoload/development.local.php

# IDEs
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db
desktop.ini

# ===== Archivos que NO deben subirse al deploy =====

# Contenido de Instagram / redes sociales (pesado, no es código)
/post_instagram/

# Scripts temporales de migración y debug
/migrations/
/scripts/
check_*.php
fix_*.php
index.html

# Scripts de diagnóstico en public
/public/diagnostico_*.php
/public/describe_*.php
/public/migracion_*.php
/public/fix_*.php

# Dump de base de datos
*.sql
