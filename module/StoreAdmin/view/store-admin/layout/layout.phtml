function navLink(string $route, string $icon, string $label, string $active, string $current): string {
    $cls = $active === $current ? ' active' : '';
    return "<li class=\"nav-item\"><a href=\"$route\" class=\"$cls\"><span class=\"material-icons\">$icon</span>$label</a></li>";
}
