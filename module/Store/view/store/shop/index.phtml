<script>
// Data from PHP
const ALL_PRODUCTS = <?= $this->products ?>;
const ALL_CATEGORIES = <?= $this->categories ?>;

// State
let cart = JSON.parse(localStorage.getItem('citrob_cart') || '[]');
let activeCategory = 'todos';
let maxPrice = 500000;
let sortMode = 'default';
let searchQuery = '';

// Cart
function toggleCart() {
  document.getElementById('cartSidebar').classList.toggle('open');
  document.getElementById('cartOverlay').classList.toggle('open');
}

function addToCart(id, name, price, img) {
  const existing = cart.find(i => i.id === id);
  if (existing) existing.qty++;
  else cart.push({ id, name, price, img, qty: 1 });
  saveCart(); renderCart(); updateBadge();
  const badge = document.querySelector(`[data-cart-id="${id}"]`);
  if (badge) { badge.textContent = 'En el carro ✓'; badge.disabled = true; setTimeout(() => { badge.textContent = 'Agregar'; badge.disabled = false; }, 1500); }
}

function removeFromCart(id) {
  cart = cart.filter(i => i.id !== id);
  saveCart(); renderCart(); updateBadge();
}

function saveCart() { localStorage.setItem('citrob_cart', JSON.stringify(cart)); }

function updateBadge() {
  const total = cart.reduce((s, i) => s + i.qty, 0);
  const badges = document.querySelectorAll('#cartBadge');
  badges.forEach(b => { b.textContent = total; b.classList.toggle('d-none', total === 0); });
}

function renderCart() {
  const container = document.getElementById('cartItems');
  const total = cart.reduce((s, i) => s + i.price * i.qty, 0);
  document.getElementById('cartCount').textContent = `(${cart.reduce((s,i)=>s+i.qty,0)})`;
  document.getElementById('cartTotal').textContent = '$' + total.toLocaleString('es-CL');
  if (!cart.length) { container.innerHTML = '<div class="text-center text-muted py-5"><span class="material-icons" style="font-size:48px;">shopping_bag</span><p class="mt-2">Carrito vacío</p></div>'; return; }
  container.innerHTML = cart.map(item => `
    <div class="d-flex align-items-center gap-3 mb-3 p-2 rounded-2" style="border:1px solid #f1f1f1;">
      <img src="${item.img || ''}" alt="" style="width:56px;height:56px;object-fit:contain;border-radius:8px;background:#f9f9f9;" onerror="this.src=''">
      <div class="flex-grow-1">
        <div style="font-size:13px;font-weight:600;">${item.name}</div>
        <div style="font-size:13px;color:var(--primary);">$${(item.price * item.qty).toLocaleString('es-CL')}</div>
        <div style="font-size:12px;color:#9ca3af;">x${item.qty} unidades</div>
      </div>
      <button class="btn btn-sm border-0 text-danger" onclick="removeFromCart(${item.id})"><span class="material-icons" style="font-size:18px;">delete</span></button>
    </div>`).join('');
}

function checkout() { alert('Funcionalidad de pago próximamente.'); }

// Render products
function renderProducts() {
  let items = [...ALL_PRODUCTS];
  if (activeCategory !== 'todos') items = items.filter(p => p.category === activeCategory);
  if (searchQuery) items = items.filter(p => p.name.toLowerCase().includes(searchQuery.toLowerCase()) || (p.description||'').toLowerCase().includes(searchQuery.toLowerCase()));
  items = items.filter(p => +p.price <= maxPrice);
  if (sortMode === 'price_asc') items.sort((a,b) => +a.price - +b.price);
  else if (sortMode === 'price_desc') items.sort((a,b) => +b.price - +a.price);
  else if (sortMode === 'name') items.sort((a,b) => a.name.localeCompare(b.name));

  document.getElementById('resultsInfo').textContent = `${items.length} productos`;
  document.getElementById('noResults').classList.toggle('d-none', items.length > 0);
  document.getElementById('productsGrid').innerHTML = items.map(p => {
    const badge = p.badge ? `<span class="product-badge" style="background:rgba(0,0,0,.08); color:#374151;">${p.badge}</span>` : '';
    const stars = Array.from({length:5},(_,i) => `<span class="material-icons" style="font-size:13px;color:${i<Math.round(+p.rating)?'#facc15':'#e5e7eb'};">star</span>`).join('');
    return `<div class="col-6 col-md-4 col-xl-3 fade-in">
      <div class="product-card h-100 position-relative">
        ${badge}
        <img src="${p.image_url||''}" class="card-img-top" alt="${p.name}" style="height:160px;padding:1rem;object-fit:contain;background:#fafafa;" onerror="this.src='';this.style.background='linear-gradient(135deg,#f8f8f8,#eee)'">
        <div class="p-3">
          <p class="text-muted mb-1" style="font-size:11px;text-transform:uppercase;letter-spacing:.5px;">${p.type||''}</p>
          <h6 class="fw-700 line-clamp-2 mb-2">${p.name}</h6>
          <div class="d-flex align-items-center gap-1 mb-2">${stars}<span style="font-size:12px;color:#9ca3af;">(${p.reviews||0})</span></div>
          <div class="d-flex align-items-center justify-content-between mt-2">
            <span class="fw-800" style="font-size:1rem;color:var(--primary);">$${(+p.price).toLocaleString('es-CL')}</span>
            <button class="btn btn-sm btn-store rounded-pill px-3" style="font-size:12px;" data-cart-id="${p.id}" onclick="addToCart(${p.id},'${p.name.replace(/'/g,"\'")}',${p.price},'${p.image_url||''}')">Agregar</button>
          </div>
          <div class="mt-1" style="font-size:11px;color:#9ca3af;">Stock: ${p.stock||0}</div>
        </div>
      </div>
    </div>`;
  }).join('');
}

// Events
document.querySelectorAll('.cat-link').forEach(a => a.addEventListener('click', e => {
  e.preventDefault(); activeCategory = a.dataset.cat;
  document.querySelectorAll('.cat-link').forEach(x => x.classList.toggle('active', x.dataset.cat === activeCategory));
  renderProducts();
}));

const priceSlider = document.getElementById('maxPrice');
if (priceSlider) priceSlider.addEventListener('input', () => {
  maxPrice = +priceSlider.value;
  document.getElementById('maxPriceLabel').textContent = '$' + maxPrice.toLocaleString('es-CL');
  renderProducts();
});

document.getElementById('sortSelect')?.addEventListener('change', e => { sortMode = e.target.value; renderProducts(); });
document.getElementById('sortSelectMobile')?.addEventListener('change', e => { sortMode = e.target.value; renderProducts(); });
document.getElementById('catSelectMobile')?.addEventListener('change', e => { activeCategory = e.target.value; renderProducts(); });

let searchTimer;
function handleSearch(val) { clearTimeout(searchTimer); searchTimer = setTimeout(() => { searchQuery = val; renderProducts(); }, 300); }
document.getElementById('searchInput')?.addEventListener('input', e => handleSearch(e.target.value));
document.getElementById('searchInputMobile')?.addEventListener('input', e => handleSearch(e.target.value));

// Init
renderProducts();
renderCart();
updateBadge();
</script>
