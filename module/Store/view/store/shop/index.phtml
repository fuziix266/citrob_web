<script>
// Data from PHP — array de productos de la BD
const products = <?= $this->products ?>.map(p => ({
    ...p,
    price: +p.price,
    rating: +p.rating,
    reviews: +p.reviews,
    // image_url ya viene como /img/products/{id}.jpg o /img/productos/{id}.jpg
    image: p.image_url ? '<?= $this->basePath('') ?>' + p.image_url : '',
    category: p.category || 'componentes',
}));

// Categorías con icono — idéntico al shop.html
const categories = [
    { id:"todos", name:"Todos los Productos", icon:"apps", count: products.length },
    <?php foreach ($categories as $cat):
        if ($cat['slug'] === 'todos') continue;
        $icon = $catIcons[$cat['slug']] ?? 'category';
    ?>
    { id:"<?= esc($cat['slug']) ?>", name:"<?= esc($cat['name']) ?>", icon:"<?= $icon ?>", count: <?= (int)$cat['count'] ?> },
    <?php endforeach; ?>
];
// Si la BD tiene categorías con slug, filtramos correctamente
categories.forEach(c => {
    if (c.id !== 'todos') c.count = products.filter(p => p.category === c.id).length;
});
categories[0].count = products.length;

let currentCategory = "todos", currentSort = "recommended", maxPrice = 100000, cart = [];
const isLoggedIn = <?= $this->isLoggedIn ? 'true' : 'false' ?>;

function renderCategories() {
    const html = categories.map(c => `
        <li><a href="#" onclick="event.preventDefault();setCategory('${c.id}')" class="cat-link ${currentCategory===c.id?'active':''}">
            <span class="d-flex align-items-center gap-2"><span class="material-icons" style="font-size:16px;">${c.icon}</span>${c.name}</span>
            <span class="cat-count">${c.count}</span>
        </a></li>
    `).join('');
    document.getElementById('categoryList').innerHTML = html;
    document.getElementById('mobileCategoryList').innerHTML = html;
}

function renderProducts() {
    let filtered = currentCategory === "todos" ? [...products] : products.filter(p => p.category === currentCategory);
    filtered = filtered.filter(p => p.price <= maxPrice);
    const search = document.getElementById('searchInput')?.value?.toLowerCase() || '';
    if (search) filtered = filtered.filter(p => p.name.toLowerCase().includes(search) || (p.type||'').toLowerCase().includes(search));
    switch(currentSort) {
        case 'price-asc':  filtered.sort((a,b) => a.price - b.price); break;
        case 'price-desc': filtered.sort((a,b) => b.price - a.price); break;
        case 'name':       filtered.sort((a,b) => a.name.localeCompare(b.name)); break;
    }

    const grid  = document.getElementById('productGrid');
    const empty = document.getElementById('emptyState');
    document.getElementById('productCount').textContent = `${filtered.length} producto${filtered.length!==1?'s':''}`;

    if (!filtered.length) { grid.innerHTML = ''; empty.classList.remove('d-none'); return; }
    empty.classList.add('d-none');

    grid.innerHTML = filtered.map(p => {
        const inCart = cart.find(c => c.id === p.id);
        const badge  = p.badge ? `<span class="product-badge ${getBadgeClass(p.badge_color || p.badgeColor)}">${p.badge}</span>` : '';
        return `
        <div class="col-6 col-lg-4 fade-in">
            <div class="product-card h-100 d-flex flex-column">
                <div class="position-relative overflow-hidden">
                    <img alt="${p.name}" class="card-img-top" src="${p.image}" loading="lazy"
                         onerror="this.src='https://placehold.co/300x300/f8f8f8/ccc?text=Producto'"/>
                    ${badge}
                </div>
                <div class="p-3 d-flex flex-column flex-grow-1">
                    <p class="text-muted text-uppercase mb-1" style="font-size:10px;letter-spacing:1px;">${p.type||''}</p>
                    <h6 class="fw-semibold small mb-3 line-clamp-2 lh-sm">${p.name}</h6>
                    <div class="mt-auto">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <span class="fw-bold fs-5">$${p.price.toLocaleString('es-CL')}</span>
                            <div class="d-flex align-items-center gap-0">${renderStars(p.rating)}<span class="text-muted ms-1" style="font-size:10px;">(${p.reviews||0})</span></div>
                        </div>
                        <button onclick="addToCart(${p.id},'${p.name.replace(/'/g,"\\'")}',${p.price},'${p.image}')"
                                class="btn btn-sm w-100 d-flex align-items-center justify-content-center gap-1 ${inCart?'btn-success':'btn-store'}">
                            <span class="material-icons" style="font-size:16px;">${inCart?'check':'add_shopping_cart'}</span>
                            ${inCart?'Agregado ✓':'Agregar al Carro'}
                        </button>
                    </div>
                </div>
            </div>
        </div>`;
    }).join('');
}

function getBadgeClass(color) {
    return {
        green:   "bg-success bg-opacity-10 text-success",
        red:     "bg-danger bg-opacity-10 text-danger",
        blue:    "bg-primary bg-opacity-10 text-primary",
        purple:  "bg-purple bg-opacity-10 text-purple-emphasis",
        primary: "text-white"
    }[color] || "bg-secondary bg-opacity-10 text-secondary";
}

function renderStars(r) {
    let h = '';
    for (let i = 1; i <= 5; i++) {
        if (i <= Math.floor(r))  h += '<span class="material-icons star-filled">star</span>';
        else if (i - .5 <= r)    h += '<span class="material-icons star-filled">star_half</span>';
        else                     h += '<span class="material-icons star-empty">star</span>';
    }
    return h;
}

function setCategory(id) {
    currentCategory = id;
    document.getElementById('categoryTitle').textContent = categories.find(c => c.id === id)?.name || '';
    renderCategories();
    renderProducts();
}

function sortProducts(v)    { currentSort = v; renderProducts(); }
function filterProducts()   { renderProducts(); }
function filterByPrice(v)   {
    maxPrice = parseInt(v);
    const l = `Hasta: $${maxPrice.toLocaleString('es-CL')}`;
    const e = document.getElementById('priceLabel');
    const m = document.getElementById('mobilePriceLabel');
    if (e) e.textContent = l;
    if (m) m.textContent = l;
    renderProducts();
}

// Cart functions via API
async function apiCall(action, payload = null) {
    const opts = { method: payload ? 'POST' : 'GET', headers: {'Content-Type':'application/json'} };
    if (payload) opts.body = JSON.stringify(payload);
    const basePath = '<?= $this->basePath('') ?>';
    const res = await fetch(basePath + '/shop/api/cart' + (action ? '/'+action : ''), opts);
    return res.json();
}

function processCartResponse(data) {
    if (data.success && data.items) {
        cart = data.items.map(i => {
            const prod = products.find(p => p.id === i.product_id);
            return {
                id: parseInt(i.product_id),
                name: i.title,
                price: parseInt(i.price),
                qty: parseInt(i.quantity),
                img: prod ? prod.image : 'https://placehold.co/300/f8f8f8/ccc?text=Producto'
            };
        });
        updateCart();
        renderProducts();
    }
}

async function loadCart() {
    if (!isLoggedIn) return;
    try {
        const data = await apiCall('');
        processCartResponse(data);
    } catch(e) { console.error('Error load cart', e); }
}

async function addToCart(id, name, price, img) {
    if (!isLoggedIn) {
        window.location.href = '<?= $this->url('admin-login') ?>';
        return;
    }
    // Optimistic UI can be done, but let's wait for the server
    const data = await apiCall('add', {product_id: parseInt(id), quantity: 1});
    processCartResponse(data);
}

async function removeFromCart(id) {
    if (!isLoggedIn) return;
    const data = await apiCall('remove', {product_id: parseInt(id)});
    processCartResponse(data);
}

async function changeQty(id, d) {
    if (!isLoggedIn) return;
    const i = cart.find(x => x.id === id);
    if (!i) return;
    if (i.qty + d <= 0) {
        removeFromCart(id);
        return;
    }
    // API adds to existing by passing quantity. Since we want to set qty, wait...
    // The PHP addAction does: newQuantity = existing.quantity + quantity;
    // So passing d as quantity will work!
    const data = await apiCall('add', {product_id: parseInt(id), quantity: d});
    processCartResponse(data);
}

async function checkoutCart() {
    if (!isLoggedIn) {
        window.location.href = '<?= $this->url('admin-login') ?>';
        return;
    }
    
    if (cart.length === 0) return;

    document.getElementById('checkoutIcon').textContent = 'hourglass_bottom';
    document.getElementById('checkoutText').textContent = 'Procesando...';
    
    try {
        const data = await apiCall('checkout', {});
        if (data.success && data.hash_id) {
            const orderUrl = `https://citrob.store/orden/${data.hash_id}`;
            const waText = `Hola, acabo de realizar un pedido en CITROB Store. Puedes ver mi orden aquí: ${orderUrl}`;
            const waUrl = `https://wa.me/56981533101?text=${encodeURIComponent(waText)}`;
            
            // Vaciar carrito visualmente
            cart = [];
            updateCart();
            renderProducts();
            
            // Redirigir a WhatsApp
            window.open(waUrl, '_blank');
        } else {
            alert(data.error || 'Ocurrió un error al procesar el pago.');
        }
    } catch (e) {
        alert('Error al conectar con el servidor.');
    } finally {
        document.getElementById('checkoutIcon').textContent = 'lock';
        document.getElementById('checkoutText').textContent = 'Proceder al Pago';
    }
}

function updateCart() {
    const b     = document.getElementById('cartBadge');
    const total = cart.reduce((s, c) => s + c.qty, 0);
    const price = cart.reduce((s, c) => s + c.price * c.qty, 0);
    if (total > 0) { b.textContent = total; b.classList.remove('d-none'); }
    else b.classList.add('d-none');

    const ci = document.getElementById('cartItems');
    const cf = document.getElementById('cartFooter');
    if (!cart.length) {
        ci.innerHTML = '<div class="text-center py-5"><span class="material-icons text-muted" style="font-size:48px;">remove_shopping_cart</span><p class="text-muted fw-medium mt-2">Tu carrito está vacío</p><p class="text-muted small">Agrega algunos productos para comenzar</p></div>';
        cf.classList.add('d-none');
        return;
    }
    cf.classList.remove('d-none');
    document.getElementById('cartTotal').textContent = `$${price.toLocaleString('es-CL')}`;
    ci.innerHTML = cart.map(i => `
        <div class="d-flex gap-3 py-3 border-bottom">
            <div class="flex-shrink-0 bg-light rounded-2 p-2" style="width:72px;height:72px;">
                <img src="${i.img}" alt="${i.name}" class="w-100 h-100" style="object-fit:contain;" onerror="this.src='https://placehold.co/72/f8f8f8/ccc?text=?'"/>
            </div>
            <div class="flex-grow-1 min-w-0">
                <h6 class="fw-semibold small line-clamp-2 mb-1">${i.name}</h6>
                <p class="fw-bold text-store small mb-2">$${i.price.toLocaleString('es-CL')}</p>
                <div class="d-flex align-items-center gap-2">
                    <button onclick="changeQty(${i.id},-1)" class="btn btn-outline-secondary btn-sm px-2 py-0" style="line-height:1.6;">−</button>
                    <span class="small fw-medium" style="width:20px;text-align:center;">${i.qty}</span>
                    <button onclick="changeQty(${i.id},1)" class="btn btn-outline-secondary btn-sm px-2 py-0" style="line-height:1.6;">+</button>
                    <button onclick="removeFromCart(${i.id})" class="btn btn-sm text-muted ms-auto p-0"><span class="material-icons" style="font-size:18px;">delete_outline</span></button>
                </div>
            </div>
        </div>
    `).join('');
}

function toggleCart() {
    const s = document.getElementById('cartSidebar');
    const o = document.getElementById('cartOverlay');
    const open = s.classList.contains('open');
    s.classList.toggle('open'); o.classList.toggle('open');
    document.body.style.overflow = open ? '' : 'hidden';
}

renderCategories();
renderProducts();
loadCart();
</script>
