// Helpers
function esc(string $s): string { return htmlspecialchars($s, ENT_QUOTES | ENT_HTML5, 'UTF-8'); }
function stars(float $r): string {
    $out = '';
    for ($i = 1; $i <= 5; $i++) {
        $out .= $i <= round($r)
            ? '<span class="material-icons star-filled" style="font-size:14px;">star</span>'
            : '<span class="material-icons star-empty" style="font-size:14px;">star</span>';
    }
    return $out;
}
