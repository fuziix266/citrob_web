<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title><?= isset($this->headTitle) ? $this->headTitle() : 'CITROB Shop' ?></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"/>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet"/>
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet"/>
    <style>
        :root { --primary:#E85D22; --primary-dark:#C94D1A; --primary-rgb:232,93,34; --bg-light:#F9FAFB; --border-c:#E5E7EB; }
        body { font-family:'Inter',sans-serif; background:var(--bg-light); }
        .btn-store { background:var(--primary); color:#fff; border:none; font-weight:600; transition:all .3s; }
        .btn-store:hover { background:var(--primary-dark); color:#fff; }
        .text-store { color:var(--primary) !important; }
        .product-card { background:#fff; border-radius:12px; border:1px solid var(--border-c); overflow:hidden; transition:all .3s cubic-bezier(.16,1,.3,1); }
        .product-card:hover { transform:translateY(-4px); box-shadow:0 12px 40px rgba(0,0,0,.1); }
        .product-card .card-img-top { background:#fff; padding:1.5rem; aspect-ratio:1; object-fit:contain; transition:transform .5s; }
        .product-card:hover .card-img-top { transform:scale(1.05); }
        .cat-link { display:flex; align-items:center; justify-content:space-between; padding:.5rem .75rem; border-radius:8px; text-decoration:none; color:#6b7280; font-size:14px; transition:all .2s; }
        .cat-link:hover { background:var(--bg-light); color:var(--primary); }
        .cat-link.active { color:var(--primary); font-weight:600; background:rgba(var(--primary-rgb),.05); }
        .cat-count { font-size:12px; padding:2px 8px; border-radius:20px; background:var(--bg-light); color:#9ca3af; }
        .cat-link.active .cat-count { background:rgba(var(--primary-rgb),.1); color:var(--primary); }
        .sidebar-card { background:#fff; border-radius:12px; border:1px solid var(--border-c); position:sticky; top:80px; max-height:calc(100vh - 100px); overflow-y:auto; }
        .star-filled { color:#facc15; font-size:14px; }
        .star-empty { color:#e5e7eb; font-size:14px; }
        .cart-sidebar { position:fixed; top:0; right:0; height:100%; width:100%; max-width:420px; background:#fff; box-shadow:-8px 0 40px rgba(0,0,0,.15); z-index:1060; transform:translateX(100%); transition:transform .3s ease; }
        .cart-sidebar.open { transform:translateX(0); }
        .cart-overlay { position:fixed; inset:0; background:rgba(0,0,0,.4); z-index:1055; display:none; }
        .cart-overlay.open { display:block; }
        .product-badge { position:absolute; top:8px; left:8px; font-size:11px; font-weight:600; padding:4px 10px; border-radius:8px; z-index:2; }
        input[type=range] { accent-color:var(--primary); }
        .line-clamp-2 { display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical; overflow:hidden; }
        @keyframes fadeIn { from{opacity:0;transform:translateY(10px)} to{opacity:1;transform:translateY(0)} }
        .fade-in { animation:fadeIn .4s ease-out forwards; }
    </style>
</head>
<body class="d-flex flex-column min-vh-100">
    <?= $this->content ?>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
